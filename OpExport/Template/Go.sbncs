#将C类型映射为Go用户侧参数类型
func func_goParamType(varType)
    case varType
        when "void"
            ret ""
        when "libop*"
            ret "uintptr"
        when "void*"
            ret "uintptr"
        when "long"
            ret "int"
        when "int"
            ret "int"
        when "double"
            ret "float64"
        when "const wchar_t*"
            ret "string"
        when "wchar_t*"
            ret "string"
        when "long*"
            ret "int"
        when "int*"
            ret "int"
        when "size_t"
            ret "uintptr"
        when "size_t*"
            ret "uintptr"
        else
            ret "uintptr"
    end
end
#将C类型映射为Go返回类型
func func_goRetType(varType)
    case varType
        when "void"
            ret ""
        when "long"
            ret "int"
        when "int"
            ret "int"
        when "double"
            ret "float64"
        when "const wchar_t*"
            ret "string"
        when "wchar_t*"
            ret "string"
        when "std::wstring"
            ret "string"
        when "long*"
            ret "int"
        else
            ret "int"
    end
end
#生成方法定义（处理返回值：long* Ret → long，std::wstring& Ret → std::wstring）
func func_genFunc(dllFunc)
    $exMethod = (_func_methodByFunction dllFunc.name)
    $findArg = null
    if ($exMethod.args | array.size) > 0
        $findTemp = $exMethod.args | array.last
        if $findTemp.rtype == 4
            $findArg = $findTemp
        end
    end
    if $findArg != null
        if $findArg.type == "long*"
            $exMethod.rtype = "long";
            if !($findArg.annotation | string.empty)
                $exMethod.annotation = $findArg.annotation;
            end
            $rIndex = ($exMethod.args | array.size) - 1
            _func_argsRemoveAt $exMethod.args $rIndex
        end
        if $findArg.type == "std::wstring&"
            $exMethod.rtype = "std::wstring";
            if !($findArg.annotation | string.empty)
                $exMethod.annotation = $findArg.annotation;
            end
            $rIndex = ($exMethod.args | array.size) - 1
            _func_argsRemoveAt $exMethod.args $rIndex
        end
    end
    ret $exMethod
end
#将Go关键字参数名重命名为安全名称
func func_goSafeName(name)
    if name == "type" || name == "range" || name == "func" || name == "map" || name == "chan" || name == "select" || name == "go" || name == "defer" || name == "fallthrough"
        ret name + "_"
    end
    ret name
end
