func _toWideStr(s string) []uint16 {
	p, _ := syscall.UTF16FromString(s)
	return p
}

func _fromWideBuf(buf []uint16) string {
	return syscall.UTF16ToString(buf)
}

type OpSoft struct {
	_lib        *syscall.DLL
	{{gDefine.ObjName}}         uintptr
