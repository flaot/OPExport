func NewOpSoft(dllFile string) (*OpSoft, error) {
	lib, err := syscall.LoadDLL(dllFile)
	if err != nil {
		return nil, err
	}
	createProc, err := lib.FindProc("{{gDefine.CreateFunc}}")
	if err != nil {
		lib.Release()
		return nil, err
	}
	op, _, _ := createProc.Call()
	return &OpSoft{_lib: lib, {{gDefine.ObjName}}: op}, nil
}

func (o *OpSoft) Release() {
	if o.{{gDefine.ObjName}} != 0 {
		if o._fn_release == nil {
			o._fn_release, _ = o._lib.FindProc("{{gDefine.ReleaseFunc}}")
		}
		if o._fn_release != nil {
			o._fn_release.Call(o.{{gDefine.ObjName}})
		}
		o.{{gDefine.ObjName}} = 0
	}
	if o._lib != nil {
		o._lib.Release()
		o._lib = nil
	}
}
