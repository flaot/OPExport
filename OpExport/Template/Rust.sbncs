#将C类型映射为Rust FFI类型（用于 extern "C" fn 签名）
func func_rustFfiType(varType)
    case varType
        when "void"
            ret "()"
        when "void*"
            ret "*mut std::os::raw::c_void"
        when "libop*"
            ret "*mut std::os::raw::c_void"
        when "long"
            ret "i32"
        when "long*"
            ret "*mut i32"
        when "int"
            ret "i32"
        when "int*"
            ret "*mut i32"
        when "wchar_t*"
            ret "*mut u16"
        when "const wchar_t*"
            ret "*const u16"
        when "double"
            ret "f64"
        when "size_t"
            ret "usize"
        when "size_t*"
            ret "*mut usize"
        else
            ret varType
    end
end
#将C类型映射为用户侧Rust类型（方法签名对外暴露的类型）
func func_rustUserType(varType)
    case varType
        when "void"
            ret "()"
        when "long"
            ret "i32"
        when "int"
            ret "i32"
        when "double"
            ret "f64"
        when "const wchar_t*"
            ret "&str"
        when "wchar_t*"
            ret "*mut u16"
        when "long*"
            ret "*mut i32"
        when "int*"
            ret "*mut i32"
        when "size_t"
            ret "usize"
        when "size_t*"
            ret "*mut usize"
        when "void*"
            ret "*mut std::os::raw::c_void"
        when "libop*"
            ret "*mut std::os::raw::c_void"
        else
            ret varType
    end
end
#将Rust保留关键字转为安全标识符（追加下划线）
func func_rustSafeIdent(name)
    $reserved = ["as", "break", "const", "continue", "crate", "else", "enum", "extern", "false", "fn", "for", "if", "impl", "in", "let", "loop", "match", "mod", "move", "mut", "pub", "ref", "return", "self", "static", "struct", "super", "trait", "true", "type", "unsafe", "use", "where", "while", "async", "await", "dyn"]
    if $reserved | array.contains name
        ret name + "_"
    end
    ret name
end
#生成方法定义（处理返回值：long* Ret → long，std::wstring& Ret → std::wstring）
func func_genFunc(dllFunc)
    $exMethod = (_func_methodByFunction dllFunc.name)
    $findArg = null
    if ($exMethod.args | array.size) > 0
        $findTemp = $exMethod.args | array.last
        if $findTemp.rtype == 4
            $findArg = $findTemp
        end
    end
    if $findArg != null
        if $findArg.type == "long*"
            $exMethod.rtype = "long";
            if !($findArg.annotation | string.empty)
                $exMethod.annotation = $findArg.annotation;
            end
            $rIndex = ($exMethod.args | array.size) - 1
            _func_argsRemoveAt $exMethod.args $rIndex
        end
        if $findArg.type == "std::wstring&"
            $exMethod.rtype = "std::wstring";
            if !($findArg.annotation | string.empty)
                $exMethod.annotation = $findArg.annotation;
            end
            $rIndex = ($exMethod.args | array.size) - 1
            _func_argsRemoveAt $exMethod.args $rIndex
        end
    end
    ret $exMethod
end
~}}
