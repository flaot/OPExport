impl Drop for OpSoft {
    fn drop(&mut self) {
        unsafe {
            if self._fn_release.is_none() {
                if let Ok(f) = self._lib.get::<Fn_{{gDefine.ReleaseFunc}}>(b"{{gDefine.ReleaseFunc}}") {
                    self._fn_release = Some(*f);
                }
            }
            if let Some(f) = self._fn_release {
                f(self._op);
            }
        }
    }
}
