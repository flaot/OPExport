# coding=UTF-8
from ctypes import *


class OpSoft:
    def __init__(self, dll_file):
        self.dll = cdll.LoadLibrary(dll_file)
        self.dll.{{gDefine.CreateFunc}}.restype = c_void_p
        self.{{gDefine.ObjName}} = self.dll.{{gDefine.CreateFunc}}()

    def __del__(self):
        self.dll.{{gDefine.ReleaseFunc}}.argtypes = [c_void_p]
        self.dll.{{gDefine.ReleaseFunc}}(self.{{gDefine.ObjName}})
        self.{{gDefine.ObjName}} = None
        self.dll = None
{{~ for $field in libOP.functions ~}}
{{~ 
if $field.name != gDefine.CreateFunc && $field.name != gDefine.ReleaseFunc
    $showFunc = func_genFunc $field
#设定方法类型语句
$orgSetTypeArray = []
$orgArgArray = []
for $arg in $field.args
    if $arg.rtype != 5 && $arg.rtype != 4
        $orgArgArray = $orgArgArray | array.add (func_switchRtnType $arg.type)
    end
end
if ($orgArgArray | array.size) > 0
    $orgSetTypeArray = $orgSetTypeArray | array.add ("self.dll." + $field.name + ".argtypes = [" + ($orgArgArray | array.join ", ") + "]")
end
if $field.rtype != "void"
    $orgSetTypeArray = $orgSetTypeArray | array.add ("self.dll." + $field.name + ".restype = " + (func_switchRtnType $field.rtype))
else
    $orgSetTypeArray = $orgSetTypeArray | array.add ("self.dll." + $field.name + ".restype = None")
end

$showArgs = [] #封装调用参数
$useArgs = [] #调用DLL的参数
$refArgs = [] #有传'可修改指针'的类型列表 与useArgs对应下标
$showArgTxtArray = []
for $arg in $field.args
    if $arg.rtype != 5 && $arg.rtype != 4
        $sType = func_switchArgType $arg.type $arg.rtype
        if $sType | string.contains "|"
            $refArgs = $refArgs | array.add ($sType | string.split "|" | array.last)
        else
            $refArgs = $refArgs | array.add ""
        end
        $arg.type = ($sType | string.split "|" | array.first)
        $useArgs = $useArgs | array.add $arg
        if $arg.name != gDefine.ObjName
            $showArgTxtArray = $showArgTxtArray | array.add ($arg.name + ": " + $arg.type)
        end
    end
end
#组装 封装调用的参数'showArgTxt'
$showArgTxt = $showArgTxtArray | array.join ", "
if ($showArgTxt | string.size) > 0
    $showArgTxt = $showArgTxt | string.prepend ", "
end
$showArgTxt = $showArgTxt | string.prepend "self"
#组装 调用DLL的参数'names'
$names = []
$curIndex = -1
for $uArg in $useArgs
    $curIndex = $curIndex + 1
    $refName = $refArgs | array.offset $curIndex | array.first
    if $refName != ""
        $names = $names | array.add ("byref(_" + $uArg.name + ")")
        continue
    end
    if $uArg.name == gDefine.ObjName
        $names = $names | array.add ("self." + $uArg.name)
    else
        $names = $names | array.add $uArg.name
    end
end
#有'可修改指针'的参数列表
$tempArg = []
$curIndex = -1
for $tName in $names
    $curIndex = $curIndex + 1
    $refName = $refArgs | array.offset $curIndex | array.first
    if $refName == ""
        continue
    end
    $uArg = $useArgs | array.offset $curIndex | array.first
    $tempArg = $tempArg | array.add $uArg
end
#有'可修改指针'的返回值类型列表
$retList = $tempArg | array.map "type"
$retText = ""
if $showFunc.rtype != "void"
    $retList = $retList | array.insert_at 0 (((func_switchArgType ($showFunc.rtype + "*") 0) | string.split "|") | array.first)
end
if ($retList | array.size) > 1
    $retText = "(" + ($retList | array.join ", ") + ")"
else
    $retText = $retList | array.first
end
 ~}}

    def {{$showFunc.name}}({{$showArgTxt}}) -> {{$retText}}:
    {{~ #代码注释 ~}}
        """
{{~ if !($showFunc.annotation | string.empty) ~}}
        {{$showFunc.annotation | string.replace "\n" " "}}
{{~ end ~}}

{{~ for $a in $showFunc.args ~}}
        {{$a.name}} -- {{$a.annotation | string.replace "\n" " "}}
{{~ end ~}}
{{~ if !($showFunc.rannotation | string.empty)~}}
        {{$showFunc.rannotation | string.replace "\n" " "}}
{{~ end ~}}
        """
{{~ for $setTypeStr in $orgSetTypeArray ~}}
        {{$setTypeStr}}
{{~ end ~}}
{{~ 
$curIndex = -1
for $name in $names 
    $curIndex = $curIndex + 1
    $refName = $refArgs | array.offset $curIndex | array.first
    if $refName != ""
        $useArg = $useArgs | array.offset $curIndex | array.first ~}}
        _{{$useArg.name}} = {{$refName}}({{$useArg.name}})
    {{~ end ~}}
{{~ end ~}}
{{~ if ($tempArg | array.size) > 0 ~}}
{{~
$tArgStr = ""
$tArgArray = []
for $tArg in $tempArg 
    $tArgArray = $tArgArray | array.add ("_" + $tArg.name + ".value")
end
$tArgStr = $tArgArray | array.join ", "
~}}
    {{~ if $showFunc.rtype == "void" ~}}
        self.dll.{{$field.name}}({{$names | array.join ", "}})
        return {{$tArgStr}}
    {{~ else ~}}
        _result = self.dll.{{$field.name}}({{$names | array.join ", "}})
        return _result, {{$tArgStr}}
    {{~ end ~}}
{{~ else ~}}
    {{~ if $showFunc.rtype == "void" ~}}
        self.dll.{{$field.name}}({{$names | array.join ", "}})
    {{~ else ~}}
        return self.dll.{{$field.name}}({{$names | array.join ", "}})
    {{~ end ~}}
{{~ end ~}}

{{~ end ~}}
{{~ end ~}}

