#转换类型    
func func_switchType(varType)
    case varType
        when "wchar_t*" 
            ret "c_wchar_p"
        when gDefine.ObjType
            ret "c_void_p"
        when "const wchar_t*" 
            ret "c_wchar_p"
        when "int*" 
            ret "POINTER(c_int)"
        when "long" 
            ret "c_long"
        when "long*" 
            ret "POINTER(c_long)"
        when "size_t" 
            ret "c_size_t"
        when "size_t*" 
            ret "POINTER(c_size_t)"
        when "void*" 
            ret "c_void_p"
        when "void" 
            ret "c_void"
        when "int" 
            ret "c_int"
        when "float" 
            ret "c_float"
        when "double" 
            ret "c_double"
        when "LONG_PTR" 
            ret "c_size_t"
        when "unsigned long" 
            ret "c_ulong"
        when "unsigned long*" 
            ret "POINTER(c_uint32)"
        when "float*" 
            ret "POINTER(c_float)"
        when "double*" 
            ret "POINTER(c_double)"
        when "int64_t" 
            ret "c_int64"
        when "int64_t*" 
            ret "POINTER(c_int64)"
        when "const void*" 
            ret "c_void_p"
        when "uint32_t"
            ret "c_uint32"
        when "uint32_t*"
            ret "POINTER(c_uint32)"
        else 
            ret varType
    end
end
#转换参数类型
func func_switchArgType(varType, refType)
    $type = (func_switchType varType)
    if refType == 4 #Ret
        ret $type
    end
    case varType
        when "float" 
            ret "float"
        when "double" 
            ret "float"
        when "long" 
            ret "int"
        when "char*" 
            ret "str|c_wchar_p"
        when "size_t*" 
            ret "int|c_size_t"
        when "const wchar_t*" 
            ret "str"
        when "int*" 
            ret "int|c_int"
        when "long*" 
            ret "int|c_long"
        when "std::wstring" 
            ret "str"
        when "unsigned long*" 
            ret "int|c_uint32"
        when "float*" 
            ret "float|c_float"
        when "double*" 
            ret "float|c_double"
        when "int64_t" 
            ret "int"
        when "int64_t*" 
            ret "int|c_int64"
        when "uint32_t"
            ret "int"
        when "uint32_t*"
            ret "int|c_uint32"
        when "std::wstring*"
            ret "str|c_wchar_p"
        when "size_t" 
            ret "int"
        when "LONG_PTR" 
            ret "int"
        when "const void*" 
            ret "int"
        when "void*" 
            ret "int"
        else 
            ret $type
    end
end
#转换返回类型
func func_switchRtnType(varType)
    ret (func_switchArgType varType 4)
end
#更改方法签名，将参数中的返回值改为返回值的类型判断
func func_switchRtnTypeCheck(varType)
case varType
  when "long*" 
      ret "long"
  when "std::wstring&" 
      ret "std::wstring"
  when "LONG_PTR*" 
      ret "int"
  when "float*" 
      ret "float"
  when "double*" 
      ret "float"
  when "int64_t*" 
      ret "int"
  when "size_t*" 
      ret "int"
  else 
      ret varType
end
end
#func_getRetArg 获取返回参数
func func_getRetArg(varOMethod)
    $tempArg = null
    for $arg in varOMethod.args
        if $arg.rtype == 4
            $tempArg = $arg
            break
        end
    end
    ret $tempArg
end

#根据原始定义生成方法定义
func func_genFunc(dllFunc)
    $exMethod = (_func_methodByFunction dllFunc.name)
    if dllFunc.name == gDefine.CreateFunc || dllFunc.name == gDefine.ReleaseFunc 
        ret dllFunc
    end
    #转移返回参数
    $findArg = func_getRetArg $exMethod
    if $findArg != null
        $retType = (func_switchRtnTypeCheck $findArg.type)
        $exMethod.rtype = $retType;
        if !($findArg.annotation | string.empty)
            $exMethod.annotation = $findArg.annotation;
        end
        $rIndex = -1
        for $arg in $exMethod.args
            $rIndex = $rIndex + 1
            if $arg.rtype == 4
                break
            end
        end
        _func_argsRemoveAt $exMethod.args $rIndex
    end
    #去除隐藏参数
    if $exMethod.args | array.size > 0
        for $i in (0..(($exMethod.args | array.size) - 1)) reversed
            if $exMethod.args[$i].rtype == 5
                _func_argsRemoveAt $exMethod.args $i
            end
        end
    end
    ret $exMethod
end
